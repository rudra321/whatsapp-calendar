# Provider selection (swap by changing these)
MESSAGE_PROVIDER=whatsapp
AI_PROVIDER=groq
CALENDAR_PROVIDER=google
NOTIFICATION_PROVIDER=messaging-bridge
HTTP_SERVER=hono

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Users (optional JSON array — users can also self-register via OAuth)
# USERS=[{"phoneNumber":"918619142679","name":"Rudra","googleRefreshToken":"1//0abc..."}]

# App
APP_URL=https://wa-cal.fly.dev
DATA_DIR=./data
PORT=3000
TIMEZONE=Asia/Kolkata
DAILY_SUMMARY_CRON=0 8 * * *
REMINDER_CHECK_CRON=* * * * *
